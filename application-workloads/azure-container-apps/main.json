      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(format('Microsoft.OperationalInsights/workspaces/{0}', parameters('workspaceName')), '2020-08-01').customerId]",
            "sharedKey": "[listKeys(format('Microsoft.OperationalInsights/workspaces/{0}', parameters('workspaceName')), '2020-08-01').primarySharedKey]"
          }
